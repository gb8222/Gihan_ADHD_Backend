generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  guest
  doctor
  admin
}

enum AccountStatus {
  pending
  approved
  rejected
}

model Profile {
  id        String        @id @db.Uuid
  email     String
  fullName  String?
  role      Role          @default(guest)
  status    AccountStatus @default(approved)

  doctor    Doctor?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  patients  Patient[]     @relation("DoctorPatients")
}

model Doctor {
  profileId   String   @id @db.Uuid
  profile     Profile  @relation(fields: [profileId], references: [id])

  licenseId   String
  idImagePath String
  approvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Patient {
  id           String   @id @default(uuid()) @db.Uuid
  patientId    String   @unique
  doctorId     String   @db.Uuid
  doctor       Profile  @relation("DoctorPatients", fields: [doctorId], references: [id])

  parentName   String
  childName    String
  contactEmail String
  passwordHash String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessments  Assessment[]
}

enum GameType {
  eye
  body
  voice
  handwriting
}

model Assessment {
  id        String   @id @default(uuid()) @db.Uuid
  patientId String   @db.Uuid
  patient   Patient  @relation(fields: [patientId], references: [id])

  game      GameType
  payload   Json

  createdAt DateTime @default(now())
}
